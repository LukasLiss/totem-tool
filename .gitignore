# TOTeM-Tool .gitignore
# Comprehensive ignore file for React + Django + Electron project

# ======================
# Node.js / React / Electron
# ======================

# Dependencies
node_modules/
*/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Production builds
frontend/build/
electron/dist/
electron/resources/

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# Logs
logs
*.log

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ======================
# Python / Django
# ======================

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
backend/venv/
backend/env/
backend/user_files/*
!backend/user_files/guest/
!backend/user_files/guest/ContainerLogistics.json
!backend/user_files/guest/ContainerLogistics.sqlite
!backend/user_files/guest/ContainerLogistics.xml
.venv/
.env/

# Django specific
backend/db.sqlite3
backend/db.sqlite3-journal
backend/media/
backend/staticfiles/
backend/static/

